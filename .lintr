linters: linters_with_defaults(
    object_length_linter(Inf)
        )
exclusions: list(
    # excluded from object_usage_linter
    "R/documentation.R" = list(
        object_usage_linter = Inf,
        return_linter = Inf
        ),
    "R/data.R" = list(
        line_length_linter = Inf
        ),
    # Don't want to functionally alter the package
    # Some compromises are necessary.
    "R/helper_functions.R" = list(
        object_name_linter = c(321,352)
        ),
    "R/metadata_df.R" = list(
        line_length_linter = 18
        ),
    "R/add_totals.R" = list(
        object_name_linter = Inf
        ),
    "R/modify_helpers.R" = list(
        object_usage_linter = c(53, 123)
    )
    )
